flowchart TD
    %% Share creation flow
    A0([Start])
    A1[User selects secret to share]
    A2{User authenticated?}
    A3[Show login page]
    A4[Check permissions on secret]
    A5{Has access?}
    A6[Show access denied]
    A7[Configure share settings]
    A8[Generate 64-char token]
    A9[Store SecretShare in DB]
    A10[Log share event]
    A11([Share link ready])

    A0 --> A1
    A1 --> A2
    A2 -- Yes --> A4
    A2 -- No --> A3
    A3 --> A2
    A4 --> A5
    A5 -- No --> A6
    A5 -- Yes --> A7
    A7 --> A8
    A8 --> A9
    A9 --> A10
    A10 --> A11

    %% Recipient access flow
    B0([Recipient opens link])
    B1[Validate token]
    B2{Token valid?}
    B3[Show invalid or expired link]
    B4[Check expiration and max views]
    B5{Expired or max views?}
    B6[Show expired or max views]
    B7{Password protected?}
    B8[Prompt for password]
    B9{Password correct?}
    B10[Show error, allow retry]
    B11[Revoke link after 5 failed attempts]
    B12[Decrypt secret]
    B13[Display secret]
    B14[Increment view count]
    B15{Burn-on-read or max views?}
    B16[Delete secret or deactivate link]
    B17([End])

    B0 --> B1
    B1 --> B2
    B2 -- No --> B3 --> B17
    B2 -- Yes --> B4
    B4 --> B5
    B5 -- Yes --> B6 --> B17
    B5 -- No --> B7
    B7 -- Yes --> B8 --> B9
    B7 -- No --> B12
    B9 -- No --> B10 --> B11
    B9 -- Yes --> B12
    B12 --> B13 --> B14 --> B15
    B15 -- Yes --> B16 --> B17
    B15 -- No --> B17

