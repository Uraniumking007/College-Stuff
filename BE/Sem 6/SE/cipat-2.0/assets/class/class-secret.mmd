classDiagram
    class Secret {
        +id: uuid
        +name: text
        +encryptedData: text
        +maxViews: int
        +viewCount: int
        +expiresAt: timestamp
        +burnOnRead: bool
    }

    class SecretShare {
        +id: uuid
        +shareToken: text
        +passwordHash: text
        +expiresAt: timestamp
        +maxViews: int
        +viewCount: int
    }

    class SecretAccessLog {
        +id: uuid
        +action: AccessAction
        +ipAddress: text
        +userAgent: text
        +accessedAt: timestamp
    }

    Secret "1" -- "0..*" SecretShare : shares
    Secret "1" -- "0..*" SecretAccessLog : logs
