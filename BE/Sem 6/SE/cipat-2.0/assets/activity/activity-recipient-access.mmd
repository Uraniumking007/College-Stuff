flowchart TD
    B0([Recipient opens link])
    B1[Validate token]
    B2{Token valid?}
    B3[Show invalid or expired link]
    B4[Check expiration and max views]
    B5{Expired or max views?}
    B6[Show expired or max views]
    B7{Password protected?}
    B8[Prompt for password]
    B9{Password correct?}
    B10[Show error, allow retry]
    B11[Revoke link after 5 failed attempts]
    B12[Decrypt secret]
    B13[Display secret]
    B14[Increment view count]
    B15{Burn-on-read or max views?}
    B16[Delete secret or deactivate link]
    B17([End])

    B0 --> B1
    B1 --> B2
    B2 -- No --> B3 --> B17
    B2 -- Yes --> B4
    B4 --> B5
    B5 -- Yes --> B6 --> B17
    B5 -- No --> B7
    B7 -- Yes --> B8 --> B9
    B7 -- No --> B12
    B9 -- No --> B10 --> B11
    B9 -- Yes --> B12
    B12 --> B13 --> B14 --> B15
    B15 -- Yes --> B16 --> B17
    B15 -- No --> B17
