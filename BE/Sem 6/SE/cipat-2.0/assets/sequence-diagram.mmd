sequenceDiagram
    actor User
    participant UI as Frontend UI
    participant API as tRPC API
    participant Auth as Auth Service
    participant Encrypt as Encryption Service
    participant DB as Database
    participant Audit as Audit Logger

    %% Secret creation
    User->>UI: Open \"Create Secret\"
    UI->>Auth: Check session
    Auth-->>UI: Session valid
    User->>UI: Fill secret form
    UI->>API: secrets.create()
    API->>Auth: validateSession()
    Auth-->>API: userId, orgId
    API->>DB: checkSecretLimit()
    DB-->>API: ok
    API->>Encrypt: encrypt(data, key)
    Encrypt-->>API: encryptedData
    API->>DB: INSERT Secret
    DB-->>API: secretId
    API->>Audit: log(\"create\", secretId)
    Audit->>DB: INSERT SecretAccessLog
    API-->>UI: success + secretId
    UI-->>User: Secret created

    %% Share link generation
    User->>UI: Click \"Share\"
    UI->>API: secrets.generateShare(secretId)
    API->>DB: SELECT Secret
    DB-->>API: secret row
    API->>API: generateToken(64 chars)
    API->>DB: INSERT SecretShare
    API->>Audit: log(\"share\", secretId)
    API-->>UI: share URL
    UI-->>User: Show copyable link

